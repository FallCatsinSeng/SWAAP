# SWAAP — Environment Variables
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to git.

# Port for the Go Wrapper API (internal only, not exposed to internet)
PORT=8081

# Cloudflare Tunnel token (dapatkan dari dashboard Cloudflare Zero Trust)
CF_TUNNEL_TOKEN=your-tunnel-token-here

# Allowed CORS origin (domain frontend kamu, tanpa trailing slash)
CORS_ORIGIN=https://swaap.yourdomain.com

# Domain yang digunakan (untuk HTTPS setup di host Nginx)
# DOMAIN=swaap.yourdomain.com
